# Grafana configuration for local development
GF_DEFAULT_APP_MODE=development

# Disable authentication in local dev (never in production!)
GF_AUTH_ANONYMOUS_ENABLED=true
GF_AUTH_ANONYMOUS_ORG_ROLE=Admin

# Enable plugin development features
GF_PLUGINS_ALLOW_LOADING_UNSIGNED_PLUGINS=timlevett-govee-datasource

# Plugin development
# Required for plugin signing when publishing to grafana.com.
# Obtain from: https://grafana.com/auth/sign-in (then Profile → Access Policies)
GRAFANA_ACCESS_POLICY_TOKEN=

# Path to your local Grafana plugins directory (for development)
# The plugin dist/ folder should be symlinked or copied here.
GRAFANA_PLUGIN_DIR=/var/lib/grafana/plugins
